{
  "name": "helixbench-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-assets": "bash scripts/prepare-assets.sh",
    "dev": "bash scripts/prepare-assets.sh && wrangler dev",
    "deploy": "bash scripts/prepare-assets.sh && wrangler deploy",
    "kv:create": "wrangler kv namespace create HELIX_CACHE",
    "kv:create-preview": "wrangler kv namespace create HELIX_CACHE --preview"
  },
  "devDependencies": {
    "wrangler": "^3.99.0"
  }
}
