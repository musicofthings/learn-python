# OpenRouter (recommended) — https://openrouter.ai/keys
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=https://github.com/musicofthings/learn-python
OPENROUTER_APP_NAME=HelixBench

# Content cache TTL (seconds). Default 86400 (24h).
# CACHE_TTL_SECONDS=86400
# CACHE_DIR=.cache/helixbench
